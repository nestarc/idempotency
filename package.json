{
  "name": "@nestarc/idempotency",
  "version": "0.2.0",
  "description": "IETF-draft-compliant idempotency module for NestJS — decorator-based, pluggable storage (memory/Redis), response replay, fingerprint validation.",
  "license": "MIT",
  "author": "nestarc",
  "homepage": "https://nestarc.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nestarc/idempotency.git"
  },
  "bugs": {
    "url": "https://github.com/nestarc/idempotency/issues"
  },
  "keywords": [
    "nestjs",
    "idempotency",
    "idempotent",
    "http",
    "ietf",
    "redis",
    "interceptor",
    "decorator",
    "nestarc"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --selectProjects unit",
    "test:watch": "jest --selectProjects unit --watch",
    "test:cov": "jest --selectProjects unit --coverage",
    "test:e2e": "jest --selectProjects e2e --runInBand",
    "test:all": "jest",
    "prepublishOnly": "npm run clean && npm run lint && npm run test:all && npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "ioredis": "^5.0.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "ioredis": "^5.4.1",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "pg": "^8.11.0",
    "prettier": "^3.3.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.10",
    "rxjs": "^7.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
